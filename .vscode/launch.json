{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch GTK CSS Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/client/**/*.js",
        "${workspaceFolder}/server/**/*.js"
      ]
    },
    {
      "name": "Attach to Language Server",
      "type": "node",
      "request": "attach",
      "port": 6009,
      "restart": true,
      "outFiles": [
        "${workspaceFolder}/server/**/*.js"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Client + Server (debug completo)",
      "configurations": ["Launch GTK CSS Extension", "Attach to Language Server"]
    }
  ]
}
